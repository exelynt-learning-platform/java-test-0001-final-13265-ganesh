public class StarPattern { // Define the class
    public static void main(String[] args) { // Main method
        int n = 10; // Number of lines in the pattern
        for (int i = 0; i < n; i++) { // Loop for each line
            for (int j = 0; j < i; j++) { // Loop to print spaces
                System.out.print(" "); // Print a space
            }
            System.out.println("*"); // Print a star and move to next line
        }
    }
}
